// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Categoria {
  id           String      @id @default(cuid())
  nombre       String      @unique
  descripcion  String?
  imagen       String?
  activo       Boolean     @default(true)
  orden        Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Subcategorías
  parentId     String?
  parent       Categoria?  @relation("SubCategorias", fields: [parentId], references: [id])
  hijos        Categoria[] @relation("SubCategorias")

  productos    Producto[]

  @@index([activo])
  @@index([orden])
  @@index([parentId])
}

model Producto {
  id             String            @id @default(cuid())
  nombre         String
  descripcion    String?
  codigoProducto String?           @unique
  codigoBarras   String?           @unique
  precio         Float             // precio base = tarjeta (el más alto)
  precioAnterior Float?
  costo          Float?

  // Precios por método de pago
  // Se calculan automáticamente al crear/editar: precio * (1 - descuentoEfectivo/100)
  descuentoEfectivo   Float   @default(10)   // % descuento para efectivo y transferencia
  precioEfectivo      Float?                 // precio * (1 - descuentoEfectivo/100)
  precioTransferencia Float?                 // igual a precioEfectivo
  precioTarjeta       Float?                 // igual a precio (para referencia explícita)

  stock          Int               @default(0)
  stockMinimo    Int               @default(1)
  unidad         String?
  imagen         String?
  imagenes       String[]          @default([])
  activo         Boolean           @default(true)
  destacado      Boolean           @default(false)
  tieneVariantes Boolean           @default(false)
  categoriaId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  categoria      Categoria?        @relation(fields: [categoriaId], references: [id])
  variantes      ProductoVariante[]
  pedidoItems    PedidoItem[]

  @@index([activo])
  @@index([categoriaId])
  @@index([destacado])
  @@index([activo, categoriaId])
  @@index([activo, destacado])
}

model ProductoVariante {
  id         String       @id @default(cuid())
  productoId String
  talle      String?
  color      String?
  stock      Int          @default(0)
  precio     Float?
  activo     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  producto    Producto     @relation(fields: [productoId], references: [id], onDelete: Cascade)
  pedidoItems PedidoItem[]

  @@unique([productoId, talle, color])
  @@index([productoId])
  @@index([productoId, activo])
}

model Cliente {
  id         String      @id @default(cuid())
  supabaseId String?     @unique
  email      String      @unique
  nombre     String
  telefono   String?
  dni        String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  direcciones Direccion[]
  pedidos     Pedido[]

  @@index([email])
  @@index([supabaseId])
}

model Direccion {
  id           String    @id @default(cuid())
  clienteId    String
  alias        String?
  calle        String
  numero       String?
  piso         String?
  departamento String?
  ciudad       String
  provincia    String
  codigoPostal String
  esPrincipal  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedidos  Pedido[]

  @@index([clienteId])
  @@index([clienteId, esPrincipal])
}

model Pedido {
  id           String       @id @default(cuid())
  clienteId    String?
  direccionId  String?
  estado       EstadoPedido @default(PENDIENTE)
  subtotal     Float
  descuento    Float        @default(0)
  costoEnvio   Float        @default(0)
  total        Float
  metodoPago   String?
  mpPaymentId  String?
  mpStatus     String?
  pagadoAt     DateTime?
  tipoEnvio    String?
  tracking     String?
  enviadoAt    DateTime?
  entregadoAt  DateTime?
  compradorNombre   String?
  compradorEmail    String?
  compradorTelefono String?
  notas        String?
  notasInternas String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  cliente   Cliente?    @relation(fields: [clienteId], references: [id])
  direccion Direccion?  @relation(fields: [direccionId], references: [id])
  items     PedidoItem[]

  @@index([estado])
  @@index([clienteId])
  @@index([mpPaymentId])
  @@index([createdAt])
  @@index([estado, createdAt])
}

model PedidoItem {
  id          String  @id @default(cuid())
  pedidoId    String
  productoId  String?
  varianteId  String?
  nombre      String
  precio      Float
  cantidad    Int
  subtotal    Float
  talle       String?
  color       String?
  imagen      String?

  pedido    Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto  Producto?         @relation(fields: [productoId], references: [id])
  variante  ProductoVariante? @relation(fields: [varianteId], references: [id])

  @@index([pedidoId])
  @@index([productoId])
}

model ConfigTienda {
  id               String   @id @default(cuid())
  mpPublicKey      String?
  mpAccessToken    String?
  mpWebhookSecret  String?
  costoEnvioBase   Float    @default(0)
  envioGratisDesde Float?
  zonaEnvio        String?
  montoMinimo      Float    @default(0)
  permitirRetiro   Boolean  @default(true)
  direccionLocal   String?
  horarioLocal     String?
  whatsapp         String?
  instagram        String?
  email            String?
  bannerTexto      String?
  politicaEnvio    String?
  politicaCambios  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum EstadoPedido {
  PENDIENTE
  PAGADO
  EN_PREPARACION
  EN_CAMINO
  ENTREGADO
  CANCELADO
  REEMBOLSADO
}
