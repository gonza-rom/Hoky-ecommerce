// prisma/schema.prisma
// Hoky Indumentaria — Tienda Online Independiente
// Base de datos propia en Supabase, sin dependencia de DevHub POS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════════════════════════════
// CATÁLOGO
// ═══════════════════════════════════════════════════════════════

model Categoria {
  id          String     @id @default(cuid())
  nombre      String     @unique
  descripcion String?
  imagen      String?
  activo      Boolean    @default(true)
  orden       Int        @default(0)   // para ordenar el menú
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  productos   Producto[]

  @@index([activo])
  @@index([orden])
}

model Producto {
  id             String            @id @default(cuid())
  nombre         String
  descripcion    String?
  codigoProducto String?           @unique
  codigoBarras   String?           @unique
  precio         Float
  precioAnterior Float?            // para mostrar precio tachado
  costo          Float?
  stock          Int               @default(0)
  stockMinimo    Int               @default(1)
  unidad         String?
  imagen         String?
  imagenes       String[]          @default([])
  activo         Boolean           @default(true)
  destacado      Boolean           @default(false)
  tieneVariantes Boolean           @default(false)
  categoriaId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  categoria      Categoria?        @relation(fields: [categoriaId], references: [id])
  variantes      ProductoVariante[]
  pedidoItems    PedidoItem[]

  @@index([activo])
  @@index([categoriaId])
  @@index([destacado])
  @@index([activo, categoriaId])
  @@index([activo, destacado])
}

model ProductoVariante {
  id         String       @id @default(cuid())
  productoId String
  talle      String?
  color      String?
  stock      Int          @default(0)
  precio     Float?       // null = usa precio base del producto
  activo     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  producto   Producto     @relation(fields: [productoId], references: [id], onDelete: Cascade)
  pedidoItems PedidoItem[]

  @@unique([productoId, talle, color])
  @@index([productoId])
  @@index([productoId, activo])
}

// ═══════════════════════════════════════════════════════════════
// CLIENTES
// ═══════════════════════════════════════════════════════════════

model Cliente {
  id         String      @id @default(cuid())
  supabaseId String?     @unique  // si usás Supabase Auth
  email      String      @unique
  nombre     String
  telefono   String?
  dni        String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  direcciones Direccion[]
  pedidos     Pedido[]

  @@index([email])
  @@index([supabaseId])
}

model Direccion {
  id           String    @id @default(cuid())
  clienteId    String
  alias        String?   // ej: "Casa", "Trabajo"
  calle        String
  numero       String?
  piso         String?
  departamento String?
  ciudad       String
  provincia    String
  codigoPostal String
  esPrincipal  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedidos  Pedido[]

  @@index([clienteId])
  @@index([clienteId, esPrincipal])
}

// ═══════════════════════════════════════════════════════════════
// PEDIDOS
// ═══════════════════════════════════════════════════════════════

model Pedido {
  id           String       @id @default(cuid())
  clienteId    String?      // null si compra como invitado
  direccionId  String?

  // Estado del pedido
  estado       EstadoPedido @default(PENDIENTE)

  // Importes
  subtotal     Float
  descuento    Float        @default(0)
  costoEnvio   Float        @default(0)
  total        Float

  // Pago
  metodoPago   String?      // mercadopago | transferencia | efectivo
  mpPaymentId  String?      // ID del pago en Mercado Pago
  mpStatus     String?      // approved | pending | rejected
  pagadoAt     DateTime?

  // Envío
  tipoEnvio    String?      // retiro | envio
  tracking     String?
  enviadoAt    DateTime?
  entregadoAt  DateTime?

  // Datos del comprador (se guardan por si el cliente no está registrado)
  compradorNombre   String?
  compradorEmail    String?
  compradorTelefono String?

  notas        String?
  notasInternas String?    // notas del comercio, no visibles al cliente

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  cliente   Cliente?    @relation(fields: [clienteId], references: [id])
  direccion Direccion?  @relation(fields: [direccionId], references: [id])
  items     PedidoItem[]

  @@index([estado])
  @@index([clienteId])
  @@index([mpPaymentId])
  @@index([createdAt])
  @@index([estado, createdAt])
}

model PedidoItem {
  id          String  @id @default(cuid())
  pedidoId    String
  productoId  String?
  varianteId  String?

  // Se guardan al momento de la compra por si el producto cambia de precio
  nombre      String
  precio      Float
  cantidad    Int
  subtotal    Float
  talle       String?
  color       String?
  imagen      String?

  pedido    Pedido            @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto  Producto?         @relation(fields: [productoId], references: [id])
  variante  ProductoVariante? @relation(fields: [varianteId], references: [id])

  @@index([pedidoId])
  @@index([productoId])
}

// ═══════════════════════════════════════════════════════════════
// CONFIGURACIÓN
// ═══════════════════════════════════════════════════════════════

model ConfigTienda {
  id    String @id @default(cuid())

  // Mercado Pago
  mpPublicKey      String?
  mpAccessToken    String?  // guardar encriptado
  mpWebhookSecret  String?

  // Envío
  costoEnvioBase   Float    @default(0)
  envioGratisDesde Float?   // null = sin envío gratis
  zonaEnvio        String?  // descripción de zonas

  // Compra mínima
  montoMinimo      Float    @default(0)

  // Retiro en local
  permitirRetiro   Boolean  @default(true)
  direccionLocal   String?
  horarioLocal     String?

  // Contacto
  whatsapp         String?
  instagram        String?
  email            String?

  // Textos
  bannerTexto      String?
  politicaEnvio    String?
  politicaCambios  String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum EstadoPedido {
  PENDIENTE      // creado, esperando pago
  PAGADO         // pago confirmado
  EN_PREPARACION // el comercio lo está preparando
  EN_CAMINO      // fue despachado
  ENTREGADO      // entregado al cliente
  CANCELADO      // cancelado
  REEMBOLSADO    // reembolso procesado
}
